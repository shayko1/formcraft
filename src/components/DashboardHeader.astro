---
interface Props {
  active?: string;
}
const { active } = Astro.props;
---
<header class="bg-white/80 backdrop-blur-md border-b border-slate-100">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
    <a href="/dashboard" class="flex items-center gap-3 text-2xl font-extrabold tracking-tight text-[var(--color-brand-dark)]">
      <span class="flex h-10 w-10 items-center justify-center rounded-2xl bg-[var(--color-brand-primary)] text-white shadow-inner shadow-white/20">◆</span>
      Form<span class="text-[var(--color-brand-primary)]">Craft</span>
    </a>
    <div class="flex items-center gap-4">
      <a
        href="/dashboard"
        class:list={["text-sm font-bold transition", active === "forms" ? "text-[var(--color-brand-primary)]" : "text-[var(--color-brand-muted)] hover:text-[var(--color-brand-primary)]"]}
      >
        My forms
      </a>
      <a href="/pricing" class="text-sm font-bold text-[var(--color-brand-muted)] transition hover:text-[var(--color-brand-primary)]">Pricing</a>
      <a href="/api/auth/logout?returnToUrl=/" class="clay-btn-secondary px-4 py-2 text-sm font-bold">
        Sign out
      </a>
    </div>
  </div>
</header>
