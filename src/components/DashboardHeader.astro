---
interface Props {
  active?: string;
}
const { active } = Astro.props;
---
<header class="border-b border-slate-100 bg-white/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3 sm:px-6 sm:py-4">
    <a
      href="/dashboard"
      class="flex min-w-0 items-center gap-2 text-lg font-extrabold tracking-tight text-[var(--color-brand-dark)] sm:gap-3 sm:text-2xl"
    >
      <span
        class="flex h-9 w-9 shrink-0 items-center justify-center rounded-2xl bg-[var(--color-brand-primary)] text-white shadow-inner shadow-white/20 sm:h-10 sm:w-10"
      >
        ◆
      </span>
      <span class="truncate">Form<span class="text-[var(--color-brand-primary)]">Craft</span></span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-4 sm:flex">
      <a
        href="/dashboard"
        class:list={[
          "whitespace-nowrap text-sm font-bold transition",
          active === "forms"
            ? "text-[var(--color-brand-primary)]"
            : "text-[var(--color-brand-muted)] hover:text-[var(--color-brand-primary)]",
        ]}
      >
        My forms
      </a>
      <a
        href="/dashboard/subscription"
        class:list={[
          "whitespace-nowrap text-sm font-bold transition",
          active === "subscription"
            ? "text-[var(--color-brand-primary)]"
            : "text-[var(--color-brand-muted)] hover:text-[var(--color-brand-primary)]",
        ]}
      >
        Subscription
      </a>
      <a
        href="/pricing"
        class="whitespace-nowrap text-sm font-bold text-[var(--color-brand-muted)] transition hover:text-[var(--color-brand-primary)]"
      >
        Pricing
      </a>
      <a
        href="/api/auth/logout?returnToUrl=/"
        class="clay-btn-secondary whitespace-nowrap px-4 py-2 text-sm font-bold"
      >
        Sign out
      </a>
    </div>

    <!-- Mobile menu (same pattern as marketing Nav) -->
    <details class="relative sm:hidden">
      <summary
        class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-xl bg-[var(--color-brand-light)] text-[var(--color-brand-dark)] [&::-webkit-details-marker]:hidden"
        aria-label="Open menu"
      >
        <span class="text-xl font-bold" aria-hidden="true">☰</span>
      </summary>
      <div class="absolute end-0 z-50 mt-2 w-48 rounded-2xl border border-slate-100 bg-white p-2 shadow-lg">
        <a
          href="/dashboard"
          class:list={[
            "block rounded-xl px-4 py-3 text-sm font-bold",
            active === "forms"
              ? "bg-[var(--color-brand-light)] text-[var(--color-brand-primary)]"
              : "text-[var(--color-brand-dark)] hover:bg-[var(--color-brand-light)]",
          ]}
        >
          My forms
        </a>
        <a
          href="/dashboard/subscription"
          class:list={[
            "block rounded-xl px-4 py-3 text-sm font-bold",
            active === "subscription"
              ? "bg-[var(--color-brand-light)] text-[var(--color-brand-primary)]"
              : "text-[var(--color-brand-dark)] hover:bg-[var(--color-brand-light)]",
          ]}
        >
          Subscription
        </a>
        <a
          href="/pricing"
          class="block rounded-xl px-4 py-3 text-sm font-bold text-[var(--color-brand-dark)] hover:bg-[var(--color-brand-light)]"
        >
          Pricing
        </a>
        <div class="my-1 h-px bg-slate-100"></div>
        <a
          href="/api/auth/logout?returnToUrl=/"
          class="block rounded-xl px-4 py-3 text-sm font-bold text-red-600 hover:bg-red-50"
        >
          Sign out
        </a>
      </div>
    </details>
  </div>
</header>
