---
import "../styles/global.css";
import Seo from "./Seo.astro";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  image?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  dir?: "rtl" | "ltr";
  lang?: string;
  bodyClass?: string;
  htmlClass?: string;
}

const {
  title,
  description,
  noindex = false,
  image,
  jsonLd,
  dir = "ltr",
  lang = "en",
  bodyClass = "bg-[var(--color-brand-light)] text-[var(--color-brand-dark)]",
  htmlClass = "",
} = Astro.props;
---

<!doctype html>
<html dir={dir} lang={lang} class={htmlClass}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#4f46e5" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <Seo title={title} description={description} noindex={noindex} image={image} jsonLd={jsonLd} />
    <slot name="head" />
  </head>
  <body class={`antialiased ${bodyClass.includes("h-dvh") || bodyClass.includes("h-full") || bodyClass.includes("overflow-hidden") ? "" : "min-h-screen "}${bodyClass}`}>
    <slot />
  </body>
</html>
