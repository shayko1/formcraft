---
import "../styles/global.css";
import Seo from "./Seo.astro";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  image?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  dir?: "rtl" | "ltr";
  lang?: string;
  bodyClass?: string;
  htmlClass?: string;
}

const {
  title,
  description,
  noindex = false,
  image,
  jsonLd,
  dir = "ltr",
  lang = "en",
  bodyClass = "bg-[var(--color-brand-light)] text-[var(--color-brand-dark)]",
  htmlClass = "",
} = Astro.props;
---

<!doctype html>
<html dir={dir} lang={lang} class={htmlClass}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#4f46e5" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Outfit:wght@400;500;700;800&display=swap"
    />
    <Seo title={title} description={description} noindex={noindex} image={image} jsonLd={jsonLd} />
    <slot name="head" />
  </head>
  <body class={`antialiased ${bodyClass.includes("h-dvh") || bodyClass.includes("h-full") || bodyClass.includes("overflow-hidden") ? "" : "min-h-screen "}${bodyClass}`}>
    {/* Re-apply Max-Age on member sessions — Wix client token refresh writes session cookies without it. */}
    <script is:inline>
      (function () {
        var MAX_AGE = 60 * 60 * 24 * 30;
        function persist() {
          try {
            var row = document.cookie.split("; ").find(function (r) { return r.indexOf("wixSession=") === 0; });
            if (!row) return;
            var raw = decodeURIComponent(row.slice("wixSession=".length));
            var parsed = JSON.parse(raw);
            if (!parsed || !parsed.tokens || !parsed.tokens.refreshToken || parsed.tokens.refreshToken.role !== "member") return;
            document.cookie =
              "wixSession=" + encodeURIComponent(raw) +
              "; path=/; secure; samesite=lax; max-age=" + MAX_AGE;
          } catch (e) {}
        }
        persist();
        document.addEventListener("visibilitychange", function () {
          if (document.visibilityState === "visible") persist();
        });
        window.addEventListener("focus", persist);
      })();
    </script>
    <slot />
  </body>
</html>
