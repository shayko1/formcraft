---
// Split showcase: builder on one side, the resulting live form on the other.
---
<section class="mx-auto max-w-6xl px-4 py-24 sm:px-6">
  <div class="grid items-center gap-12 lg:grid-cols-2">
    <div class="animate-fade-up">
      <span class="inline-flex items-center gap-2 rounded-full bg-[var(--color-brand-secondary)]/40 px-4 py-1.5 text-xs font-bold text-[var(--color-brand-primary)]">The builder</span>
      <h2 class="mt-6 text-4xl font-extrabold tracking-tight text-[var(--color-brand-dark)] sm:text-5xl">
        What you build is what they see
      </h2>
      <p class="mt-6 text-xl leading-relaxed text-[var(--color-brand-muted)] font-medium">
        A simple form that works on phones and desktops, in any language.
      </p>
      <ul class="mt-8 space-y-4">
        {[
          "Drag fields with mouse or keyboard",
          "Text, phone, email, date, and choice fields",
          "Live preview while you edit",
          "Pick an accent color per form",
        ].map((t) => (
          <li class="flex items-center gap-4 text-[var(--color-brand-dark)] font-bold text-lg">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-brand-accent)] text-white shadow-inner">✓</span>
            <span>{t}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Rendered form preview -->
    <div class="clay-card p-8 animate-floaty bg-gradient-to-br from-[var(--color-brand-blue)]/20 to-[var(--color-brand-primary)]/10">
      <div class="mx-auto max-w-sm rounded-3xl bg-white p-6 shadow-xl border border-slate-50">
        <h3 class="text-2xl font-extrabold text-[var(--color-brand-dark)]">Event Signup</h3>
        <p class="mt-2 text-sm font-bold text-[var(--color-brand-muted)]">Takes about 20 seconds.</p>
        <div class="mt-8 space-y-5">
          <div>
            <label class="mb-2 block text-sm font-bold text-[var(--color-brand-dark)]">Full name</label>
            <div class="h-12 rounded-xl bg-[var(--color-brand-light)] shadow-inner"></div>
          </div>
          <div>
            <label class="mb-2 block text-sm font-bold text-[var(--color-brand-dark)]">Email</label>
            <div class="h-12 rounded-xl bg-[var(--color-brand-light)] shadow-inner"></div>
          </div>
          <div>
            <label class="mb-2 block text-sm font-bold text-[var(--color-brand-dark)]">Ticket type</label>
            <div class="flex h-12 items-center justify-between rounded-xl bg-[var(--color-brand-light)] px-4 text-sm font-bold text-[var(--color-brand-muted)] shadow-inner">
              <span>General</span><span>▾</span>
            </div>
          </div>
          <button class="mt-4 h-14 w-full clay-btn-primary text-lg font-bold">
            Reserve my spot
          </button>
        </div>
      </div>
    </div>
  </div>
</section>
