---
// Split showcase: builder on one side, the resulting live form on the other.
---
<section class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
  <div class="grid items-center gap-12 lg:grid-cols-2">
    <div>
      <span class="text-sm font-bold uppercase tracking-wide text-brand-600">The builder</span>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
        What you build is what they see
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-slate-600">
        A simple form that works on phones and desktops, in any language.
      </p>
      <ul class="mt-6 space-y-3">
        {[
          "Drag fields with mouse or keyboard",
          "Text, phone, email, date, and choice fields",
          "Live preview while you edit",
          "Pick an accent color per form",
        ].map((t) => (
          <li class="flex items-center gap-3 text-slate-700">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-green-100 text-sm text-green-600">✓</span>
            <span class="font-medium">{t}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Rendered form preview -->
    <div class="rounded-3xl border border-slate-200 bg-gradient-to-b from-white to-slate-50 p-8 shadow-xl">
      <div class="mx-auto max-w-sm">
        <h3 class="text-xl font-extrabold text-slate-900">Event Signup</h3>
        <p class="mt-1 text-sm text-slate-500">Takes about 20 seconds.</p>
        <div class="mt-6 space-y-4">
          <div>
            <label class="mb-1 block text-sm font-semibold text-slate-700">Full name</label>
            <div class="h-10 rounded-xl border border-slate-200 bg-white"></div>
          </div>
          <div>
            <label class="mb-1 block text-sm font-semibold text-slate-700">Email</label>
            <div class="h-10 rounded-xl border border-slate-200 bg-white"></div>
          </div>
          <div>
            <label class="mb-1 block text-sm font-semibold text-slate-700">Ticket type</label>
            <div class="flex h-10 items-center justify-between rounded-xl border border-slate-200 bg-white px-3 text-sm text-slate-400">
              <span>General</span><span>▾</span>
            </div>
          </div>
          <button class="h-11 w-full rounded-xl bg-grad-brand text-sm font-bold text-white shadow-lg">
            Reserve my spot
          </button>
        </div>
      </div>
    </div>
  </div>
</section>
