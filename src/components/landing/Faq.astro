---
const faqs = [
  { q: "Do I need to code?", a: "No. You build forms by dragging fields." },
  { q: "How do people fill out my form?", a: "You get a public link when you publish. Share it by WhatsApp, email, or QR code." },
  { q: "Where are responses stored?", a: "In your Wix data. You own them and can export to CSV anytime." },
  { q: "Does it support Hebrew?", a: "Yes. RTL and Hebrew work in the form and in CSV exports for Excel." },
  { q: "Free vs Pro?", a: "Free: 1 form, 100 responses a month. Pro: unlimited forms and responses, plus duplicate detection." },
  { q: "Can I manage submissions?", a: "Yes. Each form has an admin panel to search, export, find duplicates, and delete." },
];
---
<section id="faq" class="mx-auto max-w-3xl px-4 py-20 sm:px-6">
  <div class="text-center">
    <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">Questions</h2>
  </div>
  <div class="mt-10 space-y-3">
    {faqs.map((f) => (
      <details class="group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <summary class="flex cursor-pointer list-none items-center justify-between text-base font-semibold text-slate-900 [&::-webkit-details-marker]:hidden">
          {f.q}
          <span class="ms-4 text-brand-500 transition group-open:rotate-45">+</span>
        </summary>
        <p class="mt-3 text-sm leading-relaxed text-slate-600">{f.a}</p>
      </details>
    ))}
  </div>
</section>
