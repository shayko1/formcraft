---
const faqs = [
  { q: "Do I need to code?", a: "No. You build forms by dragging fields." },
  { q: "How do people fill out my form?", a: "You get a public link when you publish. Share it by WhatsApp, email, or QR code." },
  { q: "Where are responses stored?", a: "In your Wix data. You own them and can export to CSV anytime." },
  { q: "Does it support Hebrew?", a: "Yes. RTL and Hebrew work in the form and in CSV exports for Excel." },
  { q: "Free vs Pro?", a: "Free: 1 form, 100 responses a month. Pro: unlimited forms and responses, plus duplicate detection." },
  { q: "Can I manage submissions?", a: "Yes. Each form has an admin panel to search, export, find duplicates, and delete." },
];
---
<section id="faq" class="mx-auto max-w-3xl px-4 py-24 sm:px-6">
  <div class="text-center">
    <h2 class="text-4xl font-extrabold tracking-tight text-[var(--color-brand-dark)] sm:text-5xl">Questions</h2>
  </div>
  <div class="mt-12 space-y-4">
    {faqs.map((f) => (
      <details class="group clay-card p-6">
        <summary class="flex cursor-pointer list-none items-center justify-between text-lg font-bold text-[var(--color-brand-dark)] [&::-webkit-details-marker]:hidden">
          {f.q}
          <span class="ms-4 flex h-8 w-8 items-center justify-center rounded-full bg-[var(--color-brand-light)] text-[var(--color-brand-primary)] text-xl font-bold transition group-open:rotate-45 shadow-inner">+</span>
        </summary>
        <p class="mt-4 text-base leading-relaxed text-[var(--color-brand-muted)] font-medium">{f.a}</p>
      </details>
    ))}
  </div>
</section>
