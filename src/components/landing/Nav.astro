---
// Server-rendered marketing nav. No JS — mobile uses a native <details> menu.
---
<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
    <a href="/" class="flex items-center gap-3 text-2xl font-extrabold tracking-tight text-[var(--color-brand-dark)]">
      <span class="flex h-10 w-10 items-center justify-center rounded-2xl bg-[var(--color-brand-primary)] text-white shadow-inner shadow-white/20">◆</span>
      <span>Form<span class="text-[var(--color-brand-primary)]">Craft</span></span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      <a href="/#features" class="text-base font-bold text-[var(--color-brand-muted)] transition hover:text-[var(--color-brand-primary)]">Features</a>
      <a href="/#how" class="text-base font-bold text-[var(--color-brand-muted)] transition hover:text-[var(--color-brand-primary)]">How it works</a>
      <a href="/pricing" class="text-base font-bold text-[var(--color-brand-muted)] transition hover:text-[var(--color-brand-primary)]">Pricing</a>
      <a href="/#faq" class="text-base font-bold text-[var(--color-brand-muted)] transition hover:text-[var(--color-brand-primary)]">FAQ</a>
    </div>

    <div class="hidden items-center gap-4 md:flex">
      <a href="/dashboard" class="text-base font-bold text-[var(--color-brand-muted)] transition hover:text-[var(--color-brand-primary)]">Sign in</a>
      <a href="/dashboard" class="clay-btn-primary px-6 py-2.5 text-base font-bold">
        Start free
      </a>
    </div>

    <!-- Mobile menu -->
    <details class="relative md:hidden group">
      <summary class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-xl bg-[var(--color-brand-light)] text-[var(--color-brand-dark)] [&::-webkit-details-marker]:hidden">
        <span class="text-xl font-bold">☰</span>
      </summary>
      <div class="absolute end-0 mt-3 w-52 clay-card p-2 z-50">
        <a href="/#features" class="block rounded-xl px-4 py-3 text-base font-bold text-[var(--color-brand-dark)] hover:bg-[var(--color-brand-light)]">Features</a>
        <a href="/#how" class="block rounded-xl px-4 py-3 text-base font-bold text-[var(--color-brand-dark)] hover:bg-[var(--color-brand-light)]">How it works</a>
        <a href="/pricing" class="block rounded-xl px-4 py-3 text-base font-bold text-[var(--color-brand-dark)] hover:bg-[var(--color-brand-light)]">Pricing</a>
        <a href="/#faq" class="block rounded-xl px-4 py-3 text-base font-bold text-[var(--color-brand-dark)] hover:bg-[var(--color-brand-light)]">FAQ</a>
        <div class="my-2 h-px bg-slate-100"></div>
        <a href="/dashboard" class="block rounded-xl px-4 py-3 text-base font-bold text-[var(--color-brand-primary)] hover:bg-[var(--color-brand-light)]">Sign in / Start free</a>
      </div>
    </details>
  </nav>
</header>
