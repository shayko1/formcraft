---
const features = [
  { icon: "🧲", title: "Drag and drop", body: "Add and reorder fields by dragging. No code." },
  { icon: "🧩", title: "Templates", body: "Start from parking, event, contact, or complaint forms." },
  { icon: "🔗", title: "Shareable link", body: "Publish once. Send the link by WhatsApp, email, or QR." },
  { icon: "📋", title: "Admin panel", body: "Search and filter every response in one place." },
  { icon: "📤", title: "CSV export", body: "Download to Excel. Hebrew and RTL encoding included." },
  { icon: "🔍", title: "Find duplicates", body: "Flag repeats by phone or name, then delete them." },
  { icon: "🌐", title: "Hebrew & RTL", body: "Forms work left-to-right or right-to-left." },
  { icon: "⚡", title: "Your data", body: "Responses live in your Wix account. You own them." },
];
---
<section id="features" class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      What you get
    </h2>
    <p class="mt-4 text-lg text-slate-600">
      Build the form. Share the link. Manage the replies.
    </p>
  </div>

  <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {features.map((f) => (
      <div class="group rounded-2xl border border-slate-100 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg hover:shadow-slate-900/5">
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-2xl transition group-hover:bg-brand-100">
          {f.icon}
        </div>
        <h3 class="mt-4 text-base font-bold text-slate-900">{f.title}</h3>
        <p class="mt-2 text-sm leading-relaxed text-slate-600">{f.body}</p>
      </div>
    ))}
  </div>
</section>
