---
const features = [
  { image: "/images/feature-drag-drop.png", title: "Drag and drop", body: "Add and reorder fields by dragging. No code." },
  { image: "/images/feature-templates.png", title: "Templates", body: "Start from parking, event, contact, or complaint forms." },
  { image: "/images/feature-links.png", title: "Shareable link", body: "Publish once. Send the link by WhatsApp, email, or QR." },
  { image: "/images/feature-admin.png", title: "Admin panel", body: "Search and filter every response in one place." },
  { image: "/images/feature-csv.png", title: "CSV export", body: "Download to Excel. Hebrew and RTL encoding included." },
  { image: "/images/feature-duplicate.png", title: "Find duplicates", body: "Flag repeats by phone or name, then delete them." },
  { image: "/images/feature-language.png", title: "Hebrew & RTL", body: "Forms work left-to-right or right-to-left." },
  { image: "/images/feature-private.png", title: "Your data", body: "Responses live in your Wix account. You own them." },
];
---
<section id="features" class="mx-auto max-w-6xl px-4 py-24 sm:px-6">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-4xl font-extrabold tracking-tight text-[var(--color-brand-dark)] sm:text-5xl">
      What you get
    </h2>
    <p class="mt-6 text-xl text-[var(--color-brand-muted)] font-medium">
      Build the form. Share the link. Manage the replies.
    </p>
  </div>

  <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
    {features.map((f, i) => (
      <div class="group clay-card p-6 flex flex-col items-start animate-fade-up" style={`animation-delay: ${i * 100}ms;`}>
        <div class="mb-6 h-32 w-full overflow-hidden rounded-xl bg-[var(--color-brand-light)] shadow-inner">
          <img src={f.image} alt={f.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" />
        </div>
        <h3 class="text-xl font-bold text-[var(--color-brand-dark)] tracking-tight">{f.title}</h3>
        <p class="mt-3 text-base leading-relaxed text-[var(--color-brand-muted)]">{f.body}</p>
      </div>
    ))}
  </div>
</section>
