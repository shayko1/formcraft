---
const year = new Date().getFullYear();
---
<footer class="border-t border-slate-100 bg-white">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
      <a href="/" class="flex items-center gap-2 text-lg font-extrabold tracking-tight">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-grad-brand text-white">◆</span>
        Form<span class="text-gradient">Craft</span>
      </a>
      <nav class="flex flex-wrap items-center justify-center gap-6 text-sm font-medium text-slate-600">
        <a href="/#features" class="transition hover:text-slate-900">Features</a>
        <a href="/#how" class="transition hover:text-slate-900">How it works</a>
        <a href="/pricing" class="transition hover:text-slate-900">Pricing</a>
        <a href="/#faq" class="transition hover:text-slate-900">FAQ</a>
        <a href="/dashboard" class="transition hover:text-slate-900">Sign in</a>
      </nav>
    </div>
    <div class="mt-8 flex flex-col items-center justify-between gap-2 border-t border-slate-100 pt-6 text-xs text-slate-400 sm:flex-row">
      <p>© {year} FormCraft. Built on Wix.</p>
    </div>
  </div>
</footer>
