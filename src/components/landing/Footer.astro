---
const year = new Date().getFullYear();
---
<footer class="border-t border-slate-100 bg-white">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="flex flex-col items-center justify-between gap-8 sm:flex-row">
      <a href="/" class="flex items-center gap-3 text-2xl font-extrabold tracking-tight text-[var(--color-brand-dark)]">
        <span class="flex h-10 w-10 items-center justify-center rounded-2xl bg-[var(--color-brand-primary)] text-white shadow-inner shadow-white/20">◆</span>
        <span>Form<span class="text-[var(--color-brand-primary)]">Craft</span></span>
      </a>
      <nav class="flex flex-wrap items-center justify-center gap-8 text-sm font-bold text-[var(--color-brand-muted)]">
        <a href="/#features" class="transition hover:text-[var(--color-brand-primary)]">Features</a>
        <a href="/#how" class="transition hover:text-[var(--color-brand-primary)]">How it works</a>
        <a href="/pricing" class="transition hover:text-[var(--color-brand-primary)]">Pricing</a>
        <a href="/#faq" class="transition hover:text-[var(--color-brand-primary)]">FAQ</a>
        <a href="/dashboard" class="transition hover:text-[var(--color-brand-primary)]">Sign in</a>
      </nav>
    </div>
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-slate-100 pt-8 text-sm font-bold text-[var(--color-brand-muted)] sm:flex-row">
      <p>© {year} FormCraft. Built on Wix.</p>
    </div>
  </div>
</footer>
