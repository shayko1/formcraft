---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;

const freeFeatures = [
  "1 published form",
  "100 responses / month",
  "All field types & templates",
  "Public link & admin panel",
  "CSV export",
];
const proFeatures = [
  "Unlimited published forms",
  "Unlimited responses",
  "Duplicate detection",
  "Custom accent colors",
  "Priority support",
];
---
<section id="pricing" class={compact ? "py-8" : "bg-slate-50 py-20"}>
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    {!compact && (
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
          Pricing
        </h2>
        <p class="mt-4 text-lg text-slate-600">Start free. Pay when you need more.</p>
      </div>
    )}

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      <!-- Free -->
      <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
        <h3 class="text-lg font-bold text-slate-900">Free</h3>
        <p class="mt-2 text-sm text-slate-500">Try it with one form.</p>
        <div class="mt-5 flex items-baseline gap-1">
          <span class="text-4xl font-extrabold text-slate-900">$0</span>
          <span class="text-sm text-slate-500">/ month</span>
        </div>
        <ul class="mt-6 space-y-3">
          {freeFeatures.map((f) => (
            <li class="flex items-center gap-3 text-sm text-slate-700">
              <span class="text-green-500">✓</span>{f}
            </li>
          ))}
        </ul>
        <a href="/dashboard" class="mt-8 block rounded-xl border border-slate-200 bg-white py-3 text-center text-sm font-semibold text-slate-800 transition hover:bg-slate-50">
          Get started free
        </a>
      </div>

      <!-- Pro -->
      <div class="relative rounded-3xl border-2 border-brand-500 bg-white p-8 shadow-xl shadow-brand-500/10">
        <span class="absolute -top-3 end-6 rounded-full bg-grad-brand px-3 py-1 text-xs font-bold text-white">Most popular</span>
        <h3 class="text-lg font-bold text-slate-900">Pro</h3>
        <p class="mt-2 text-sm text-slate-500">Unlimited forms and responses.</p>
        <div class="mt-5 flex items-baseline gap-1">
          <span class="text-4xl font-extrabold text-slate-900">$12</span>
          <span class="text-sm text-slate-500">/ month</span>
        </div>
        <ul class="mt-6 space-y-3">
          {proFeatures.map((f) => (
            <li class="flex items-center gap-3 text-sm text-slate-700">
              <span class="text-brand-500">✓</span>{f}
            </li>
          ))}
        </ul>
        <a href="/dashboard" class="mt-8 block rounded-xl bg-grad-brand py-3 text-center text-sm font-bold text-white shadow-lg transition hover:opacity-90">
          Upgrade to Pro
        </a>
      </div>
    </div>
  </div>
</section>
