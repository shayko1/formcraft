---
import UpgradeButton from "../UpgradeButton";
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;

const freeFeatures = [
  "1 form",
  "View up to 100 responses per form",
  "All field types & templates",
  "Public link & admin panel",
  "CSV export",
];
const proFeatures = [
  "Unlimited forms",
  "Unlimited responses",
  "Duplicate detection",
  "Custom accent colors",
  "Priority support",
];
---
<section id="pricing" class={compact ? "py-12" : "bg-white py-24"}>
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    {!compact && (
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-4xl font-extrabold tracking-tight text-[var(--color-brand-dark)] sm:text-5xl">
          Pricing
        </h2>
        <p class="mt-6 text-xl text-[var(--color-brand-muted)] font-medium">Start free. Pay when you need more.</p>
      </div>
    )}

    <div class="mt-16 grid gap-8 md:grid-cols-2">
      <!-- Free -->
      <div class="clay-card p-8 animate-fade-up">
        <h3 class="text-2xl font-bold text-[var(--color-brand-dark)]">Free</h3>
        <p class="mt-3 text-base font-bold text-[var(--color-brand-muted)]">Try it with one form.</p>
        <div class="mt-6 flex items-baseline gap-2">
          <span class="text-6xl font-extrabold text-[var(--color-brand-dark)]">$0</span>
          <span class="text-lg font-bold text-[var(--color-brand-muted)]">/ month</span>
        </div>
        <ul class="mt-8 space-y-4">
          {freeFeatures.map((f) => (
            <li class="flex items-center gap-4 text-lg font-bold text-[var(--color-brand-dark)]">
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-[var(--color-brand-light)] text-[var(--color-brand-primary)]">✓</span>{f}
            </li>
          ))}
        </ul>
        <a href="/dashboard" class="mt-10 block w-full clay-btn-secondary py-4 text-center text-lg font-bold">
          Get started free
        </a>
      </div>

      <!-- Pro -->
      <div class="relative clay-card p-8 animate-fade-up bg-gradient-to-br from-white to-[var(--color-brand-secondary)]/20" style="animation-delay: 150ms;">
        <span class="absolute -top-5 end-8 rounded-full bg-[var(--color-brand-primary)] px-4 py-2 text-sm font-bold text-white shadow-lg shadow-[var(--color-brand-primary)]/30">Most popular</span>
        <h3 class="text-2xl font-bold text-[var(--color-brand-dark)]">Pro</h3>
        <p class="mt-3 text-base font-bold text-[var(--color-brand-muted)]">Unlimited forms and responses.</p>
        <div class="mt-6 flex items-baseline gap-2">
          <span class="text-6xl font-extrabold text-[var(--color-brand-dark)]">€12</span>
          <span class="text-lg font-bold text-[var(--color-brand-muted)]">/ month</span>
        </div>
        <ul class="mt-8 space-y-4">
          {proFeatures.map((f) => (
            <li class="flex items-center gap-4 text-lg font-bold text-[var(--color-brand-dark)]">
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-[var(--color-brand-primary)] text-white shadow-inner">✓</span>{f}
            </li>
          ))}
        </ul>
        <div class="mt-10">
          <UpgradeButton client:load label="Upgrade to Pro" className="block w-full clay-btn-primary py-4 text-center text-lg font-bold" />
        </div>
      </div>
    </div>
  </div>
</section>
