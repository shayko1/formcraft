---
const steps = [
  { n: "1", image: "/images/step-template.webp", title: "Pick a template", body: "Parking, event, contact, or blank. Open it and start editing." },
  { n: "2", image: "/images/step-customize.webp", title: "Edit the fields", body: "Drag fields, change labels, mark required ones. Preview updates as you go." },
  { n: "3", image: "/images/step-publish.webp", title: "Publish the link", body: "Share the URL. New responses show up in your admin panel." },
];
---
<section id="how" class="bg-white py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-4xl font-extrabold tracking-tight text-[var(--color-brand-dark)] sm:text-5xl">
        How it works
      </h2>
      <p class="mt-6 text-xl text-[var(--color-brand-muted)] font-medium">Three steps. No setup.</p>
    </div>

    <div class="relative mt-16 grid gap-8 md:grid-cols-3">
      {steps.map((s, i) => (
        <div class="relative clay-card p-7 animate-fade-up" style={`animation-delay: ${i * 150}ms;`}>
          <div class="absolute -top-5 -left-5 flex h-12 w-12 items-center justify-center rounded-full bg-[var(--color-brand-primary)] text-xl font-bold text-white shadow-lg shadow-[var(--color-brand-primary)]/30 z-10">
            {s.n}
          </div>
          <div class="mb-6 h-40 w-full overflow-hidden rounded-xl bg-[var(--color-brand-light)] shadow-inner">
            <img
              src={s.image}
              alt={s.title}
              width="800"
              height="533"
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover"
            />
          </div>
          <h3 class="mt-5 text-2xl font-bold text-[var(--color-brand-dark)] tracking-tight">{s.title}</h3>
          <p class="mt-3 text-base leading-relaxed text-[var(--color-brand-muted)]">{s.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
