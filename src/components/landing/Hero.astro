---
// Hero — zero JS. The "builder mockup" is pure HTML/CSS/SVG for PageSpeed.
---
<section class="relative overflow-hidden bg-dots">
  <div class="pointer-events-none absolute inset-x-0 -top-40 h-80 bg-grad-soft blur-3xl"></div>

  <div class="relative mx-auto grid max-w-6xl items-center gap-12 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:py-24">
    <!-- Copy -->
    <div class="animate-fade-up">
      <span class="inline-flex items-center gap-2 rounded-full bg-[var(--color-brand-blue)]/30 px-4 py-1.5 text-xs font-bold text-[var(--color-brand-dark)]">
        <span class="h-2 w-2 rounded-full bg-blue-400"></span>
        No code · Works on Wix
      </span>

      <h1 class="mt-6 text-5xl font-extrabold leading-tight tracking-tight text-[var(--color-brand-dark)] sm:text-6xl lg:text-7xl">
        Forms you can
        <span class="text-gradient">build in minutes.</span>
      </h1>

      <p class="mt-6 max-w-lg text-xl leading-relaxed text-[var(--color-brand-muted)] font-medium">
        Drag fields into place, publish a link, and collect responses.
        Search, export to CSV, and spot duplicates from one admin panel.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a href="/dashboard" class="clay-btn-primary px-8 py-4 text-lg font-bold">
          Start free
        </a>
        <a href="/#how" class="clay-btn-secondary px-8 py-4 text-lg font-bold">
          How it works
        </a>
      </div>

      <p class="mt-6 text-sm font-semibold text-[var(--color-brand-muted)]">
        Free: 1 form, view up to 100 responses. No credit card.
      </p>
    </div>

    <!-- Builder mockup -->
    <div class="relative animate-floaty">
      <div class="clay-card p-6">
        <div class="mb-5 flex items-center gap-2 border-b border-slate-100 pb-4">
          <span class="h-3 w-3 rounded-full bg-red-400 shadow-inner"></span>
          <span class="h-3 w-3 rounded-full bg-amber-400 shadow-inner"></span>
          <span class="h-3 w-3 rounded-full bg-green-400 shadow-inner"></span>
          <span class="ms-2 text-xs font-bold text-[var(--color-brand-muted)]">formcraft · Parking Registration</span>
        </div>

        <div class="grid grid-cols-3 gap-5">
          <!-- Palette -->
          <div class="col-span-1 space-y-3 rounded-2xl bg-[var(--color-brand-light)] p-3 shadow-inner">
            {["Text", "Phone", "Email", "Date", "Choice"].map((t) => (
              <div class="flex items-center gap-2 rounded-xl bg-white px-3 py-2.5 text-xs font-bold text-[var(--color-brand-dark)] shadow-sm">
                <span class="text-[var(--color-brand-primary)]">⋮⋮</span>{t}
              </div>
            ))}
          </div>

          <!-- Canvas -->
          <div class="col-span-2 space-y-4">
            <div class="rounded-2xl bg-[var(--color-brand-blue)]/20 p-4 shadow-sm">
              <div class="text-[10px] font-bold text-[var(--color-brand-dark)]">FIRST NAME</div>
              <div class="mt-2 h-8 rounded-xl bg-white shadow-inner"></div>
            </div>
            <div class="rounded-2xl bg-white p-4 shadow-sm border border-slate-50">
              <div class="text-[10px] font-bold text-[var(--color-brand-dark)]">PHONE</div>
              <div class="mt-2 h-8 rounded-xl bg-[var(--color-brand-light)] shadow-inner"></div>
            </div>
            <div class="rounded-2xl border-2 border-dashed border-[var(--color-brand-primary)]/30 bg-[var(--color-brand-primary)]/5 p-4 text-center text-[11px] font-bold text-[var(--color-brand-primary)]">
              + drop a field here
            </div>
            <div class="mt-2 h-12 rounded-xl bg-grad-brand text-center text-sm font-bold leading-[3rem] text-white shadow-md">
              Submit
            </div>
          </div>
        </div>
      </div>

      <!-- floating "published" chip -->
      <div class="absolute -bottom-6 -start-6 clay-card px-5 py-4 z-10">
        <div class="flex items-center gap-3 text-sm font-bold text-[var(--color-brand-dark)]">
          <span class="flex h-8 w-8 items-center justify-center rounded-full bg-[var(--color-brand-accent)] text-white shadow-inner">✓</span>
          Published in 30s
        </div>
      </div>
    </div>
  </div>
</section>
