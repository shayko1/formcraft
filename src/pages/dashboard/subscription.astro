---
import Layout from "../../components/Layout.astro";
import DashboardHeader from "../../components/DashboardHeader.astro";
import SubscriptionPanel from "../../components/SubscriptionPanel";
import { getCurrentMemberId, loginRedirect } from "../../lib/session";
import { getSubscriptionSummary } from "../../lib/subscription";

const memberId = await getCurrentMemberId();
if (!memberId) return Astro.redirect(loginRedirect(Astro.url.pathname));

let summary: Awaited<ReturnType<typeof getSubscriptionSummary>> | null = null;
let error: string | null = null;

try {
  summary = await getSubscriptionSummary(memberId);
} catch (e) {
  error = e instanceof Error ? e.message : String(e);
}
---
<Layout title="Subscription" noindex bodyClass="bg-[var(--color-brand-light)] text-[var(--color-brand-dark)]">
  <DashboardHeader active="subscription" />
  <main class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <div class="mb-8">
      <h1 class="text-4xl font-extrabold tracking-tight text-[var(--color-brand-dark)]">Subscription</h1>
      <p class="mt-2 text-sm font-bold text-[var(--color-brand-muted)]">
        Plan status, billing history, and cancellation
      </p>
    </div>

    {error ? (
      <div class="clay-card border border-red-100 bg-red-50 p-6 text-sm font-bold text-red-900">
        <strong>Couldn't load your subscription.</strong> {error}
      </div>
    ) : summary ? (
      <SubscriptionPanel client:load summary={summary} />
    ) : null}
  </main>
</Layout>
