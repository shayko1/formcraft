---
import Layout from "../../../components/Layout.astro";
import DashboardHeader from "../../../components/DashboardHeader.astro";
import TemplatePicker, { type TemplateCard } from "../../../components/TemplatePicker";
import { getCurrentMemberId, loginRedirect } from "../../../lib/session";
import { TEMPLATES } from "../../../lib/templates";

const memberId = await getCurrentMemberId();
if (!memberId) return Astro.redirect(loginRedirect(Astro.url.pathname));

const cards: TemplateCard[] = TEMPLATES.map((t) => ({
  id: t.id,
  name: t.name,
  description: t.description,
  icon: t.icon,
  fieldCount: t.fields.length,
}));
---
<Layout title="New form" noindex bodyClass="bg-slate-50 text-slate-900">
  <DashboardHeader />
  <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
    <div class="mb-6">
      <a href="/dashboard" class="text-sm font-medium text-slate-500 hover:text-slate-700">← Back to my forms</a>
      <h1 class="mt-2 text-2xl font-extrabold tracking-tight text-slate-900">New form</h1>
      <p class="mt-1 text-sm text-slate-500">Pick a template. You can change everything later.</p>
    </div>
    <TemplatePicker client:load templates={cards} />
  </main>
</Layout>
