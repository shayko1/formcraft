---
import Layout from "../../../../components/Layout.astro";
import FormBuilder from "../../../../components/builder/FormBuilder";
import { getCurrentMemberId, loginRedirect } from "../../../../lib/session";
import { getFormById } from "../../../../lib/forms";

const { id } = Astro.params;
const memberId = await getCurrentMemberId();
if (!memberId) return Astro.redirect(loginRedirect(Astro.url.pathname));

const form = id ? await getFormById(id) : null;
if (!form) return new Response("Form not found", { status: 404 });
if (form.ownerId !== memberId) return new Response("You don't have access to this form.", { status: 403 });

const origin = Astro.url.origin;
---
<Layout title={`Edit · ${form.title}`} noindex bodyClass="h-dvh overflow-hidden bg-slate-100 text-slate-900">
  <div class="h-full w-full min-w-0 overflow-hidden">
    <FormBuilder
      client:load
      formId={form.id}
      slug={form.slug}
      initialTitle={form.title}
      initialDescription={form.description}
      initialFields={form.fields}
      initialInternalFields={form.internalFields}
      initialTheme={form.theme}
      initialPublished={form.published}
      origin={origin}
    />
  </div>
</Layout>
