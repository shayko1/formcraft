---
import Layout from "../../components/Layout.astro";
import DashboardHeader from "../../components/DashboardHeader.astro";
import FormsList, { type FormSummary } from "../../components/FormsList";
import { getCurrentMemberId, loginRedirect } from "../../lib/session";
import { listFormsByOwner } from "../../lib/forms";
import { getQuotaStatus } from "../../lib/plan";

const memberId = await getCurrentMemberId();
if (!memberId) return Astro.redirect(loginRedirect(Astro.url.pathname));

let forms: FormSummary[] = [];
let quota: Awaited<ReturnType<typeof getQuotaStatus>> | null = null;
let error: string | null = null;

try {
  const [list, q] = await Promise.all([listFormsByOwner(memberId), getQuotaStatus(memberId)]);
  forms = list.map((f) => ({
    id: f.id,
    title: f.title,
    slug: f.slug,
    published: f.published,
    submissionCount: f.submissionCount,
    templateId: f.templateId,
  }));
  quota = q;
} catch (e) {
  error = e instanceof Error ? e.message : String(e);
}

const origin = Astro.url.origin;
---
<Layout title="My forms" noindex bodyClass="bg-[var(--color-brand-light)] text-[var(--color-brand-dark)]">
  <DashboardHeader active="forms" />
  <main class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="mb-8 flex flex-wrap items-center justify-between gap-4">
      <div>
        <h1 class="text-4xl font-extrabold tracking-tight text-[var(--color-brand-dark)]">My forms</h1>
        {quota && (
          <p class="mt-2 text-sm font-bold text-[var(--color-brand-muted)]">
            {quota.tier === "pro" ? "Pro plan · unlimited" : `Free plan · ${quota.publishedForms}/${quota.maxPublishedForms} published · ${quota.submissionsThisMonth}/${quota.maxSubmissionsPerMonth} responses this month`}
          </p>
        )}
      </div>
      <a href="/dashboard/forms/new" class="clay-btn-primary px-6 py-3 text-sm font-bold">
        + New form
      </a>
    </div>

    {error ? (
      <div class="clay-card bg-red-50 p-6 text-sm font-bold text-red-900 border border-red-100">
        <strong>Couldn't load your forms.</strong> {error}
      </div>
    ) : (
      <>
        {quota && quota.tier === "free" && !quota.canPublishMore && (
          <div class="mb-8 flex flex-wrap items-center justify-between gap-4 clay-card bg-[var(--color-brand-yellow)]/20 p-6 border border-[var(--color-brand-yellow)]/50">
            <p class="text-base font-bold text-[var(--color-brand-dark)]">You've reached your free plan limit. Upgrade to publish more forms.</p>
            <a href="/pricing" class="clay-btn-primary px-6 py-3 text-sm font-bold">Upgrade</a>
          </div>
        )}
        <FormsList client:load forms={forms} origin={origin} />
      </>
    )}
  </main>
</Layout>
