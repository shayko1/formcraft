---
import Layout from "../../components/Layout.astro";
import FormRenderer from "../../components/FormRenderer";
import { getFormBySlug, getPublicFormContent } from "../../lib/forms";
import { getCurrentMemberId } from "../../lib/session";
import {
  DEFAULT_THEME,
  resolveCardAppearance,
  resolvePageBackground,
  usesCanvasLayout,
  isDarkCardBackground,
} from "../../lib/form-schema";

const { slug } = Astro.params;
const form = slug ? await getFormBySlug(slug) : null;
const available = form && form.published;
const pub = available ? getPublicFormContent(form!) : null;
const theme = { ...DEFAULT_THEME, ...(pub?.theme ?? {}) };
const dir = theme.dir ?? "ltr";
const page = resolvePageBackground(theme);
const card = resolveCardAppearance(theme);
const darkCard = isDarkCardBackground(theme);
const isInk = theme.pageBackground === "ink";
const canvas = available && pub ? usesCanvasLayout(theme, pub.fields) : false;
const pageStyle = page.style
  ? Object.entries(page.style)
      .map(([k, v]) => `${k}:${v}`)
      .join(";")
  : undefined;
const cardStyle = Object.entries(card.style)
  .map(([k, v]) => `${k}:${v}`)
  .join(";");

const memberId = available ? await getCurrentMemberId() : null;
const isOwner = !!(form && memberId && form.ownerId === memberId);
---
<Layout
  title={available && pub ? pub.title : "Form unavailable"}
  description={available && pub ? pub.description || `Fill out ${pub.title}` : undefined}
  noindex
  dir={dir}
  lang={dir === "rtl" ? "he" : "en"}
  bodyClass={page.bodyClass}
>
  <div class="min-h-screen" style={pageStyle}>
    {isOwner && form && (
      <div class:list={[
        "sticky top-0 z-40 border-b px-3 py-2.5 text-center text-sm font-semibold backdrop-blur",
        isInk
          ? "border-slate-700/80 bg-slate-950/80 text-slate-200"
          : "border-slate-200/80 bg-white/90 text-slate-700",
      ]}>
        You're the owner of this form.
        <a
          href={`/dashboard/forms/${form.id}/submissions`}
          class:list={[
            "ms-2 inline-flex items-center gap-1 underline-offset-2 hover:underline",
            isInk ? "text-indigo-300" : "text-indigo-600",
          ]}
        >
          View responses
          <span aria-hidden="true">→</span>
        </a>
        <span class:list={["mx-2", isInk ? "text-slate-600" : "text-slate-300"]}>·</span>
        <a
          href={`/dashboard/forms/${form.id}/edit`}
          class:list={[
            "underline-offset-2 hover:underline",
            isInk ? "text-slate-300" : "text-slate-500",
          ]}
        >
          Edit form
        </a>
      </div>
    )}
    <main class:list={[
      "mx-auto flex min-h-screen flex-col justify-center px-3 py-8 sm:px-4 sm:py-10",
      canvas ? "max-w-3xl" : "max-w-xl",
    ]}>
      {available && pub ? (
        <div class:list={[card.className, darkCard && "[&_h1]:text-slate-50 [&_label]:text-slate-200 [&_p]:text-slate-300"]} style={cardStyle}>
          <FormRenderer
            client:load
            formId={form!.id}
            title={pub.title}
            description={pub.description}
            fields={pub.fields}
            theme={theme}
          />
        </div>
      ) : (
        <div class="rounded-3xl bg-white p-10 text-center shadow-sm ring-1 ring-slate-100">
          <span class="text-4xl">🔒</span>
          <h1 class="mt-4 text-xl font-extrabold text-slate-900">This form isn't available</h1>
          <p class="mt-2 text-sm text-slate-500">The link may be incorrect, or the form is no longer accepting responses.</p>
          <a href="/" class="mt-6 inline-block rounded-xl bg-grad-brand px-5 py-2.5 text-sm font-semibold text-white">Go to FormCraft</a>
        </div>
      )}
      <p class:list={["mt-6 text-center text-xs", isInk ? "text-slate-500" : "text-slate-400"]}>
        Powered by <a href="/" class:list={["font-semibold", isInk ? "text-slate-300 hover:text-white" : "text-slate-500 hover:text-slate-700"]}>FormCraft</a>
      </p>
    </main>
  </div>
</Layout>
